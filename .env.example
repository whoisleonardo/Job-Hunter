# =========================================================================== #
# Job Hunter — variáveis de ambiente do BACKEND
# ---------------------------------------------------------------------------
# COMO USAR:
#   1. Copie este arquivo para ".env"   ->   cp .env.example .env
#   2. Preencha os valores reais no .env (NUNCA commite o .env)
#   3. Rode: python backend.py
# O .env é lido automaticamente pelo backend (via python-dotenv).
# No host (Render/Railway/etc.), defina estas mesmas variáveis no painel.
# =========================================================================== #

# --- Fontes de vagas (todas com plano grátis) ---
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
JOOBLE_API_KEY=
SERPAPI_KEY=

# --- Telegram (crie o bot com @BotFather) ---
TELEGRAM_BOT_TOKEN=

# --- Códigos de acesso: um por amigo, separados por vírgula ---
ACCESS_CODES=CODIGO-AMIGO-1,CODIGO-AMIGO-2

# --- IA do match: AGORA É POR USUÁRIO ---
#     Cada usuário escolhe o provedor (Anthropic, DeepSeek, OpenAI, Groq, Ollama
#     local ou qualquer endpoint compatível com o formato OpenAI), a base URL, o
#     modelo e a própria chave — tudo pelo app. O servidor NÃO impõe provedor
#     nem exige chave nenhuma.
#
#     As variáveis abaixo são OPCIONAIS: definem apenas uma chave de IA GLOBAL de
#     fallback, usada quando um usuário não informa a chave dele. Deixe vazias
#     para o match cair no modo heurístico por palavra-chave quando faltar chave.
#     LLM_API_KEY vale para o provedor padrão (Anthropic); ANTHROPIC_API_KEY
#     continua aceita por compatibilidade.
LLM_API_KEY=
ANTHROPIC_API_KEY=

# --- Ajustes opcionais ---
# Máximo de requisições por código por hora
RATE_PER_HOUR=120
# Pasta onde salvar prefs.json/seen.json (use um disco persistente em produção)
DATA_DIR=.
# Porta HTTP (Render define automaticamente via $PORT)
PORT=8000
